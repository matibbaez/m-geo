---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "MGEO | Matías Georgetta. Estructura legal corporativa y representación deportiva profesional." } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/logo-abogados.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="antialiased flex flex-col min-h-screen selection:bg-brand-primary selection:text-white bg-brand-white">
    
    <header id="main-header" class="fixed w-full top-0 z-50 bg-transparent border-b border-transparent transition-all duration-500 py-6">
      <div class="container mx-auto px-6 md:px-10 flex justify-between items-center">
        
        <a href="/" id="logo-link" class="flex items-center gap-3 md:gap-4 group z-50 text-white transition-colors duration-500">
          <div class="flex flex-col justify-center">
            <span class="text-2xl md:text-3xl font-heading font-bold leading-none tracking-[0.15em] uppercase">
              MGEO
            </span>
            <span id="logo-accent" class="text-[7.5px] md:text-[9px] font-body font-medium tracking-[0.25em] uppercase mt-1 transition-colors duration-500 opacity-90">
              MATÍAS GEORGETTA
            </span>
          </div>
        </a>
        
        <div class="hidden lg:flex items-center gap-8">
          <nav>
            <ul id="nav-links" class="flex items-center gap-8 text-[11px] font-body font-semibold tracking-[0.2em] text-white transition-colors duration-500 uppercase">
              <li>
                <a href="/estudio" class="flex items-center gap-2 group hover:text-brand-primary transition-colors duration-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-primary opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
                  MGEO Abogados
                </a>
              </li>
              <li>
                <a href="/sports" class="flex items-center gap-2 group hover:text-brand-primary transition-colors duration-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-primary opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
                  MGEO Sports
                </a>
              </li>
            </ul>
          </nav>
          
          <div id="nav-divider" class="w-px h-6 bg-white/30 transition-colors duration-500"></div>
          
          <a id="nav-cta" href="#contacto" class="text-[10px] font-body font-bold uppercase tracking-[0.2em] text-white border border-white/30 px-6 py-2.5 hover:bg-white hover:text-brand-dark transition-all duration-500 rounded-sm">
            Contacto
          </a>
        </div>

        <button id="mobile-menu-btn" class="lg:hidden z-50 relative focus:outline-none w-10 h-10 flex flex-col justify-center items-end gap-[6px] group overflow-hidden" aria-label="Abrir Menú">
          <span class="w-7 h-[2px] bg-white transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] origin-center" id="line1"></span>
          <span class="w-5 h-[2px] bg-brand-primary transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] origin-center group-hover:w-7" id="line2"></span>
          <span class="w-7 h-[2px] bg-white transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] origin-center" id="line3"></span>
        </button>
      </div>
    </header>

    <div id="mobile-menu" class="fixed inset-0 bg-brand-dark/98 backdrop-blur-2xl opacity-0 pointer-events-none transition-opacity duration-500 z-45 flex flex-col pt-36 pb-12 overflow-y-auto">
      <div class="container mx-auto px-8 w-full flex flex-col h-full grow">
        <nav class="flex flex-col gap-8 w-full mt-4">
          <a href="/estudio" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-100">
            <span class="text-brand-primary font-body text-xs tracking-widest opacity-50">01</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-brand-primary transition-colors">MGEO Abogados</span>
          </a>
          <a href="/sports" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-200">
            <span class="text-brand-primary font-body text-xs tracking-widest opacity-50">02</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-brand-primary transition-colors">MGEO Sports</span>
          </a>
          <a href="#contacto" class="mobile-link group flex items-center gap-6 border-b border-white/10 pb-6 translate-y-8 opacity-0 transition-all duration-500 delay-300">
            <span class="text-brand-primary font-body text-xs tracking-widest opacity-50">03</span>
            <span class="text-3xl font-heading font-light text-white group-hover:text-brand-primary transition-colors">Contacto</span>
          </a>
        </nav>
      </div>
    </div>

    <main class="grow">
      <slot />
    </main>

    <footer class="bg-brand-dark text-gray-400 pt-24 pb-8 border-t border-white/5 relative z-20 overflow-hidden">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-primary/10 rounded-full blur-[150px] pointer-events-none -translate-y-1/2 translate-x-1/3"></div>
      <div class="container mx-auto px-6 md:px-10 grid grid-cols-1 md:grid-cols-12 gap-16 lg:gap-12 mb-20 relative z-10">
        <div class="md:col-span-12 lg:col-span-5 pr-0 lg:pr-12">
          
          <div class="flex flex-col justify-center mb-8 inline-flex">
            <span class="text-2xl md:text-3xl font-heading font-bold text-white leading-none tracking-[0.15em] uppercase">
              MGEO<span class="text-brand-primary">.</span>
            </span>
            <span class="text-[7.5px] md:text-[9px] font-body font-medium tracking-[0.25em] uppercase mt-1 text-brand-primary opacity-90">
              MATÍAS GEORGETTA
            </span>
          </div>

          <p class="text-sm font-light leading-loose text-gray-400 mb-8 max-w-sm">
            Estructura legal corporativa orientada a resultados y agencia de representación para deportistas profesionales.
          </p>
        </div>
        
        <div class="md:col-span-6 lg:col-span-3">
          <span class="text-white uppercase tracking-[0.2em] text-[10px] font-bold mb-8 flex items-center gap-3"><span class="w-3 h-px bg-brand-primary"></span> Unidades</span>
          <ul class="space-y-4 text-sm font-light text-gray-400">
            <li><a href="/estudio" class="hover:text-brand-primary transition-colors flex items-center gap-3 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-700 group-hover:bg-brand-primary transition-colors"></span> Estudio Jurídico</a></li>
            <li><a href="/sports" class="hover:text-brand-primary transition-colors flex items-center gap-3 group"><span class="w-1.5 h-1.5 rounded-full bg-gray-700 group-hover:bg-brand-primary transition-colors"></span> MGEO Sports</a></li>
          </ul>
        </div>
        
        <div class="md:col-span-6 lg:col-span-4">
          <span class="text-white uppercase tracking-[0.2em] text-[10px] font-bold mb-8 flex items-center gap-3"><span class="w-3 h-px bg-brand-primary"></span> Contacto Central</span>
          <ul class="space-y-4 text-sm font-light text-gray-400">
            <li><a href="mailto:contacto@mgeo.com.ar" class="hover:text-white transition-colors">contacto@mgeo.com.ar</a></li>
            <li>Buenos Aires, Argentina</li>
          </ul>
        </div>
      </div>
      
      <div class="container mx-auto px-6 md:px-10 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-[9px] uppercase tracking-[0.2em] font-body text-gray-500 font-medium">
        <p>© {new Date().getFullYear()} MGEO. Todos los derechos reservados.</p>
        <div class="flex items-center gap-2"><span>Diseño y Arquitectura por</span><a href="#" class="text-brand-primary hover:text-white transition-colors font-bold">VisionPath</a></div>
      </div>
    </footer>

    <script>
      import Lenis from 'lenis';
      const lenis = new Lenis({ duration: 1.5, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
      function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);

      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const header = document.getElementById('main-header');
      const mobileLinks = document.querySelectorAll('.mobile-link');
      
      const logoLink = document.getElementById('logo-link');
      const logoSvg = document.getElementById('logo-svg');
      const logoAccent = document.getElementById('logo-accent');
      const navLinks = document.getElementById('nav-links');
      const navDivider = document.getElementById('nav-divider');
      const navCta = document.getElementById('nav-cta');
      
      const line1 = document.getElementById('line1');
      const line2 = document.getElementById('line2');
      const line3 = document.getElementById('line3');

      let isScrolled = false;
      let isMenuOpen = false;

      const closeMenu = () => {
        isMenuOpen = false;
        menu?.classList.remove('opacity-100', 'pointer-events-auto');
        menu?.classList.add('opacity-0', 'pointer-events-none');
        
        // Ocultar los links del menú móvil
        mobileLinks.forEach(link => {
          link.classList.remove('opacity-100', 'translate-y-0');
          link.classList.add('opacity-0', 'translate-y-8');
        });

        const targetLineColor = isScrolled ? 'bg-brand-dark' : 'bg-white';
        line1?.classList.replace('bg-brand-primary', targetLineColor);
        line3?.classList.replace('bg-brand-primary', targetLineColor);
        
        line1?.classList.remove('rotate-45', 'translate-y-[8px]');
        line2?.classList.remove('opacity-0', 'translate-x-4');
        line3?.classList.remove('-rotate-45', '-translate-y-[8px]');
        
        if (isScrolled) {
            header?.classList.replace('bg-transparent', 'bg-white/95');
            header?.classList.add('backdrop-blur-xl', 'shadow-sm', 'border-gray-100');
            logoLink?.classList.replace('text-white', 'text-brand-dark');
        }
        lenis.start();
      };

      const openMenu = () => {
        isMenuOpen = true;
        menu?.classList.remove('opacity-0', 'pointer-events-none');
        menu?.classList.add('opacity-100', 'pointer-events-auto');
        
        // Mostrar los links del menú móvil con animación
        mobileLinks.forEach(link => {
          link.classList.remove('opacity-0', 'translate-y-8');
          link.classList.add('opacity-100', 'translate-y-0');
        });

        const currentLineColor = isScrolled ? 'bg-brand-dark' : 'bg-white';
        line1?.classList.replace(currentLineColor, 'bg-brand-primary');
        line3?.classList.replace(currentLineColor, 'bg-brand-primary');
        
        line1?.classList.add('rotate-45', 'translate-y-[8px]');
        line2?.classList.add('opacity-0', 'translate-x-4');
        line3?.classList.add('-rotate-45', '-translate-y-[8px]');
        
        if (isScrolled) {
            header?.classList.replace('bg-white/95', 'bg-transparent');
            header?.classList.remove('backdrop-blur-xl', 'shadow-sm', 'border-gray-100');
            logoLink?.classList.replace('text-brand-dark', 'text-white');
        }
        lenis.stop();
      };

      btn?.addEventListener('click', () => isMenuOpen ? closeMenu() : openMenu());

      // Cerrar menú al hacer clic en un enlace móvil
      mobileLinks.forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      lenis.on('scroll', (e: any) => {
        if (!isMenuOpen) {
          if (e.scroll > 50 && !isScrolled) {
            isScrolled = true;
            header?.classList.replace('bg-transparent', 'bg-white/95');
            header?.classList.add('backdrop-blur-xl', 'shadow-sm', 'border-gray-100');
            header?.classList.replace('py-6', 'py-4');
            
            logoLink?.classList.replace('text-white', 'text-brand-dark');
            logoSvg?.classList.add('text-brand-primary');
            logoAccent?.classList.add('text-brand-primary');
            
            navLinks?.classList.replace('text-white', 'text-brand-dark');
            navDivider?.classList.replace('bg-white/30', 'bg-gray-200');
            
            navCta?.classList.replace('text-white', 'text-brand-primary');
            navCta?.classList.replace('border-white/30', 'border-brand-primary/50');
            navCta?.classList.replace('hover:bg-white', 'hover:bg-brand-primary');
            navCta?.classList.replace('hover:text-brand-dark', 'hover:text-white');

            line1?.classList.replace('bg-white', 'bg-brand-dark');
            line3?.classList.replace('bg-white', 'bg-brand-dark');
          } else if (e.scroll <= 50 && isScrolled) {
            isScrolled = false;
            header?.classList.replace('bg-white/95', 'bg-transparent');
            header?.classList.remove('backdrop-blur-xl', 'shadow-sm', 'border-gray-100');
            header?.classList.replace('py-4', 'py-6');
            
            logoLink?.classList.replace('text-brand-dark', 'text-white');
            logoSvg?.classList.remove('text-brand-primary');
            logoAccent?.classList.remove('text-brand-primary');
            
            navLinks?.classList.replace('text-brand-dark', 'text-white');
            navDivider?.classList.replace('bg-gray-200', 'bg-white/30');

            navCta?.classList.replace('text-brand-primary', 'text-white');
            navCta?.classList.replace('border-brand-primary/50', 'border-white/30');
            navCta?.classList.replace('hover:bg-brand-primary', 'hover:bg-white');
            navCta?.classList.replace('hover:text-white', 'hover:text-brand-dark');

            line1?.classList.replace('bg-brand-dark', 'bg-white');
            line3?.classList.replace('bg-brand-dark', 'bg-white');
          }
        }
      });
    </script>
  </body>
</html>