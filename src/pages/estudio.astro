  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const wpForm = document.getElementById('wp-form') as HTMLFormElement | null;
      
      if (wpForm) {
        wpForm.addEventListener('submit', function(e) {
          e.preventDefault(); // Evitamos que la página se recargue

          // Obtenemos los elementos y le decimos a TypeScript qué tipo de input son
          const nombreInput = document.getElementById('nombre') as HTMLInputElement | null;
          const contactoInput = document.getElementById('contacto_dato') as HTMLInputElement | null;
          const selectArea = document.getElementById('area') as HTMLSelectElement | null;
          const mensajeInput = document.getElementById('mensaje') as HTMLTextAreaElement | null;

          // Verificamos que no sean nulos para que el linter no tire errores
          if (!nombreInput || !contactoInput || !selectArea || !mensajeInput) return;

          const nombre = nombreInput.value;
          const contacto = contactoInput.value;
          const area = selectArea.options[selectArea.selectedIndex].value;
          const mensaje = mensajeInput.value;

          // ⚠️ IMPORTANTE: ACÁ PONÉS EL NÚMERO DE TELÉFONO DEL ESTUDIO ⚠️
          const numeroWhatsApp = "5491100000000"; 

          // Armamos la estructura del mensaje
          const textoBase = 
`Hola Estudio MGEO, me contacto desde la web para realizar una consulta.

*Datos del cliente:*
👤 Nombre/Empresa: ${nombre}
📞 Contacto alternativo: ${contacto}

*Área legal de interés:*
⚖️ ${area}

*Detalle de la consulta:*
${mensaje}

Aguardo sus comentarios. ¡Gracias!`;

          // Codificamos el texto para la URL
          const textoCodificado = encodeURIComponent(textoBase);

          // Generamos el enlace y lo abrimos
          const urlWhatsApp = `https://wa.me/${numeroWhatsApp}?text=${textoCodificado}`;
          window.open(urlWhatsApp, '_blank');
        });
      }
    });
  </script>

