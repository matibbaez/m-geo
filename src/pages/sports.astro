---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MGEO Sports | Representación de Futbolistas | Agente FIFA">
  
  <section class="relative bg-brand-dark text-white min-h-[90vh] md:min-h-screen flex items-center px-6 md:px-12 overflow-hidden pt-32 pb-20">
    <div class="absolute inset-0 z-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>
    <div class="absolute bottom-0 right-0 w-[40rem] h-[40rem] bg-brand-primary/15 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <div class="container mx-auto max-w-5xl relative z-10 w-full">
      <div class="inline-flex items-center gap-3 mb-8 bg-white/5 border border-white/10 rounded-full px-5 py-2 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
        <span class="text-gray-300 font-body text-[10px] tracking-widest uppercase font-bold">Unidad Deportiva de MGEO</span>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-[6.5rem] font-heading font-bold leading-[1.05] mb-8 tracking-tight">
        Llevamos tu carrera <br />
        <span class="italic font-light text-gray-400">al próximo nivel<span class="text-brand-primary">.</span></span>
      </h1>

      <p class="text-lg md:text-xl font-light text-gray-400 max-w-2xl mb-12 leading-relaxed border-l-2 border-brand-primary pl-6">
        Representación estratégica integral para futbolistas profesionales. Negociación, blindaje jurídico y desarrollo deportivo bajo estándares internacionales.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-6">
        <a href="#contacto-sports" class="bg-brand-primary text-white px-10 py-5 font-body font-bold uppercase tracking-[0.2em] text-[11px] hover:bg-white hover:text-brand-dark transition-all duration-500 w-full sm:w-auto text-center shadow-[0_10px_30px_-10px_rgba(120,22,22,0.5)]">
          Contactar Agencia
        </a>
        <a href="#perfil-agente" class="text-white hover:text-brand-primary transition-colors font-body font-semibold text-[11px] uppercase tracking-[0.2em] group flex items-center justify-center gap-4 w-full sm:w-auto py-4">
          Conocer al Agente <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-y-2 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </a>
      </div>
    </div>
  </section>

  <section id="perfil-agente" class="py-24 md:py-32 bg-white px-6 border-b border-gray-100">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="lg:col-span-5">
          <span class="text-brand-primary font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 block">Director & Agente</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-brand-dark leading-[1.1] mb-8 tracking-tight">
            Matías Georgetta<br/>
            <span class="italic font-light text-gray-400">Agente Oficial.</span>
          </h2>
          <p class="text-gray-600 font-light text-base md:text-lg leading-relaxed mb-8">
            MGEO Sports fusiona el conocimiento exhaustivo del marco legal con la pasión por el fútbol. Al estar respaldados por nuestra propia firma jurídica, garantizamos que cada paso en tu carrera esté protegido, blindado y optimizado.
          </p>
          
          <div class="flex flex-col gap-4 pt-6 border-t border-gray-100">
            <div class="flex items-center gap-4 bg-[#F9F8F6] p-4 rounded-sm border border-gray-100">
              <div class="w-12 h-12 bg-brand-dark text-brand-primary flex items-center justify-center rounded-sm shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
              </div>
              <div>
                <span class="text-[10px] font-body font-bold uppercase tracking-widest text-brand-primary leading-tight">Credencial Oficial</span>
                <p class="font-heading font-bold text-brand-dark text-xl">Licencia FIFA ID 202305-1916</p>
              </div>
            </div>
            <a href="https://instagram.com/matias.georgetta" target="_blank" rel="noopener noreferrer" class="text-sm font-body font-medium text-gray-500 hover:text-brand-primary transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.036 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/></svg>
              @matias.georgetta
            </a>
          </div>
        </div>
        
        <div class="lg:col-span-7">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="bg-[#F9F8F6] p-8 md:p-10 border border-gray-100 hover:border-brand-primary/30 transition-colors">
              <svg class="w-8 h-8 text-brand-primary mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>
              <h3 class="text-xl font-heading font-bold text-brand-dark mb-3">Respaldo Jurídico</h3>
              <p class="text-gray-500 text-sm font-light leading-relaxed">No tercerizamos lo legal. Somos un estudio jurídico y una agencia al mismo tiempo. Blindamos tus contratos de punta a punta.</p>
            </div>
            <div class="bg-brand-dark p-8 md:p-10 border border-brand-dark transform sm:translate-y-8 shadow-2xl">
              <svg class="w-8 h-8 text-brand-primary mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
              <h3 class="text-xl font-heading font-bold text-white mb-3">Proyección Global</h3>
              <p class="text-gray-400 text-sm font-light leading-relaxed">Conexiones directas y licencia oficial de FIFA que nos permite operar, negociar y realizar transferencias en todo el mundo sin intermediarios secundarios.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="talentos" class="py-24 md:py-32 bg-[#0a0a0a] text-white px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[40rem] h-[40rem] bg-brand-primary/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="container mx-auto max-w-6xl relative z-10">
      
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <span class="text-brand-primary font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 block">Representación Oficial</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold tracking-tight text-white">Team MGEO.</h2>
        </div>
        <a href="https://instagram.com/matias.georgetta" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors font-body text-[10px] md:text-xs uppercase tracking-[0.2em] flex items-center gap-3 border-b border-gray-700 hover:border-brand-primary pb-2 group">
          Ver firmas en Instagram
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[1px] bg-white/10 border border-white/10">
        
        <div class="group relative aspect-[4/5] bg-[#111] overflow-hidden cursor-pointer">
          <img src="https://images.unsplash.com/photo-1511886929837-354d827aae26?q=80&w=800&auto=format&fit=crop" alt="Jugador MGEO" class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" />
          
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-90 group-hover:opacity-70 transition-opacity duration-500"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="text-brand-primary text-[10px] font-bold tracking-[0.2em] uppercase mb-2 block opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">Cat. 2004</span>
            <h3 class="text-xl md:text-2xl font-heading font-bold text-white mb-1">Lucas <br/> Martínez</h3>
            <div class="w-6 h-px bg-brand-primary my-3 group-hover:w-12 transition-all duration-500"></div>
            <p class="text-xs font-body font-light text-gray-400 uppercase tracking-wider">Club Atlético Independiente</p>
          </div>
        </div>

        <div class="group relative aspect-[4/5] bg-[#111] overflow-hidden cursor-pointer">
          <img src="https://images.unsplash.com/photo-1553778263-73a83bab9b0c?q=80&w=800&auto=format&fit=crop" alt="Jugador MGEO" class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-90 group-hover:opacity-70 transition-opacity duration-500"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="text-brand-primary text-[10px] font-bold tracking-[0.2em] uppercase mb-2 block opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">Cat. 2006</span>
            <h3 class="text-xl md:text-2xl font-heading font-bold text-white mb-1">Mateo <br/> Fernández</h3>
            <div class="w-6 h-px bg-brand-primary my-3 group-hover:w-12 transition-all duration-500"></div>
            <p class="text-xs font-body font-light text-gray-400 uppercase tracking-wider">Boca Juniors</p>
          </div>
        </div>

        <div class="group relative aspect-[4/5] bg-[#111] overflow-hidden cursor-pointer">
          <img src="https://images.unsplash.com/photo-1600250395353-841dbadceeb3?q=80&w=800&auto=format&fit=crop" alt="Jugador MGEO" class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-90 group-hover:opacity-70 transition-opacity duration-500"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="text-brand-primary text-[10px] font-bold tracking-[0.2em] uppercase mb-2 block opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">Cat. 2003</span>
            <h3 class="text-xl md:text-2xl font-heading font-bold text-white mb-1">Tomás <br/> Silva</h3>
            <div class="w-6 h-px bg-brand-primary my-3 group-hover:w-12 transition-all duration-500"></div>
            <p class="text-xs font-body font-light text-gray-400 uppercase tracking-wider">San Lorenzo</p>
          </div>
        </div>

        <div class="group relative aspect-[4/5] bg-[#111] overflow-hidden cursor-pointer">
          <img src="https://images.unsplash.com/photo-1543326727-cf6c39e8f84c?q=80&w=800&auto=format&fit=crop" alt="Jugador MGEO" class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-90 group-hover:opacity-70 transition-opacity duration-500"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="text-brand-primary text-[10px] font-bold tracking-[0.2em] uppercase mb-2 block opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">1ra División</span>
            <h3 class="text-xl md:text-2xl font-heading font-bold text-white mb-1">Agustín <br/> Gómez</h3>
            <div class="w-6 h-px bg-brand-primary my-3 group-hover:w-12 transition-all duration-500"></div>
            <p class="text-xs font-body font-light text-gray-400 uppercase tracking-wider">Club Atlético Banfield</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="servicios-sports" class="py-24 md:py-32 bg-[#F9F8F6] px-6">
    <div class="container mx-auto max-w-6xl">
      
      <div class="text-center mb-20">
        <span class="text-brand-primary font-body font-bold tracking-[0.3em] uppercase text-xs mb-4 block">Nuestros Servicios</span>
        <h2 class="text-4xl md:text-5xl font-heading font-bold text-brand-dark tracking-tight">Estructura Deportiva.</h2>
        <p class="text-gray-500 font-light text-lg mt-4 max-w-2xl mx-auto">Cubrimos todas las aristas necesarias para el desarrollo integral del deportista profesional.</p>
      </div>

      <div class="space-y-12">
        
        <div class="bg-white shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] border border-gray-100 flex flex-col xl:flex-row overflow-hidden">
          <div class="xl:w-5/12 bg-brand-dark text-white p-10 md:p-14 relative overflow-hidden flex flex-col justify-center">
            <div class="absolute top-0 left-0 w-64 h-64 bg-brand-primary/10 rounded-full blur-[80px]"></div>
            <div class="relative z-10">
              <h3 class="text-3xl md:text-4xl font-heading font-bold mb-6 leading-tight">Intermediación y <br/><span class="text-brand-primary italic">Transferencias</span></h3>
              <p class="text-gray-300 font-light mb-8 leading-relaxed">
                Gestión operativa y legal de contratos laborales con clubes a nivel nacional e internacional.
              </p>
            </div>
          </div>
          
          <div class="xl:w-7/12 p-10 md:p-14 bg-white flex flex-col justify-center">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <h4 class="text-brand-dark font-bold font-heading text-lg mb-2">Para Futbolistas</h4>
                <p class="text-gray-500 text-sm font-light leading-relaxed">Búsqueda de oportunidades de mercado, negociación de salarios, primas, bonos por objetivos y condiciones de traspaso.</p>
              </div>
              <div>
                <h4 class="text-brand-dark font-bold font-heading text-lg mb-2">Para Clubes</h4>
                <p class="text-gray-500 text-sm font-light leading-relaxed">Mandatos oficiales para scouting, colocación de jugadores y estructuración de operaciones de compra/venta o cesión.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] border border-gray-100 flex flex-col xl:flex-row-reverse overflow-hidden">
          <div class="xl:w-5/12 bg-[#161616] text-white p-10 md:p-14 relative overflow-hidden flex flex-col justify-center">
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-brand-primary/10 rounded-full blur-[80px]"></div>
            <div class="relative z-10">
              <h3 class="text-3xl md:text-4xl font-heading font-bold mb-6 leading-tight">Asesoramiento <br/><span class="text-brand-primary italic">Legal y Financiero</span></h3>
              <p class="text-gray-300 font-light mb-8 leading-relaxed">
                El respaldo directo del Estudio Jurídico MGEO aplicado a la carrera del deportista.
              </p>
            </div>
          </div>
          
          <div class="xl:w-7/12 p-10 md:p-14 bg-white">
            <ul class="space-y-4">
                <li class="flex items-start gap-4 p-4 border border-gray-100 rounded-sm bg-gray-50/50 hover:bg-white hover:shadow-md transition-all">
                  <span class="text-brand-primary font-bold mt-1">01</span>
                  <div>
                    <h5 class="font-heading font-bold text-brand-dark mb-1">Derechos de Formación y Solidaridad</h5>
                    <p class="text-xs text-gray-500 font-light">Gestión y reclamo ante FIFA por derechos formativos para clubes y academias.</p>
                  </div>
                </li>
                <li class="flex items-start gap-4 p-4 border border-gray-100 rounded-sm bg-gray-50/50 hover:bg-white hover:shadow-md transition-all">
                  <span class="text-brand-primary font-bold mt-1">02</span>
                  <div>
                    <h5 class="font-heading font-bold text-brand-dark mb-1">Conflictos Contractuales</h5>
                    <p class="text-xs text-gray-500 font-light">Defensa en tribunales ordinarios o cámara de resolución de disputas (TAS/CAS).</p>
                  </div>
                </li>
                <li class="flex items-start gap-4 p-4 border border-gray-100 rounded-sm bg-gray-50/50 hover:bg-white hover:shadow-md transition-all">
                  <span class="text-brand-primary font-bold mt-1">03</span>
                  <div>
                    <h5 class="font-heading font-bold text-brand-dark mb-1">Planificación Patrimonial</h5>
                    <p class="text-xs text-gray-500 font-light">Estructuración fiscal e inversiones para asegurar el futuro económico post-retiro.</p>
                  </div>
                </li>
            </ul>
          </div>
        </div>

        <div class="bg-white shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] border border-brand-primary/20 flex flex-col xl:flex-row overflow-hidden relative">
          <div class="absolute top-0 left-0 w-1 h-full bg-brand-primary"></div>
          <div class="xl:w-5/12 bg-brand-dark text-white p-10 md:p-14 relative overflow-hidden flex flex-col justify-center">
            <div class="relative z-10">
              <h3 class="text-3xl md:text-4xl font-heading font-bold mb-6 leading-tight">Desarrollo de <br/><span class="text-brand-primary italic">Imagen y Sponsoreo</span></h3>
              <p class="text-gray-300 font-light leading-relaxed">
                El futbolista actual es una marca. Gestionamos acuerdos comerciales y presencia digital para maximizar los ingresos extra-deportivos.
              </p>
            </div>
          </div>
          
          <div class="xl:w-7/12 p-10 md:p-14 bg-white flex items-center">
            <div class="grid grid-cols-2 gap-6 w-full">
               <div class="border-l-2 border-brand-primary pl-4">
                  <h5 class="text-brand-dark font-bold text-sm uppercase tracking-wider mb-2">Marcas Deportivas</h5>
                  <p class="text-xs text-gray-500 font-light">Negociación de contratos de indumentaria y botas.</p>
               </div>
               <div class="border-l-2 border-gray-200 pl-4">
                  <h5 class="text-brand-dark font-bold text-sm uppercase tracking-wider mb-2">Social Media</h5>
                  <p class="text-xs text-gray-500 font-light">Asesoramiento en comunicación, manejo de crisis y PR.</p>
               </div>
               <div class="border-l-2 border-gray-200 pl-4">
                  <h5 class="text-brand-dark font-bold text-sm uppercase tracking-wider mb-2">Sponsors</h5>
                  <p class="text-xs text-gray-500 font-light">Vinculación con marcas comerciales locales y globales.</p>
               </div>
               <div class="border-l-2 border-brand-primary pl-4">
