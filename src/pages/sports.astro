---
import Layout from '../layouts/Layout.astro';

// ACÁ PODÉS EDITAR LA INFO DE LOS 11 JUGADORES
const roster = [
  { img: "/jugador1-lucero.jpeg", nombre: "Matías Lucero", tag: "Volante", club: "Arsenal FC", link: "https://www.instagram.com/p/DXh8bBMkcbp/?igsh=bG5pbzN2czY1M28w" },
  { img: "/jugador2-bermejo.jpeg", nombre: "Mauri Bermejo", tag: "Volante", club: "Ituzaingó", link: "https://www.instagram.com/p/DS3HvSVj05a/?igsh=b2hpNmVmbmw3MDY2" },
  { img: "/jugador3-otero.jpeg", nombre: "Federico Otero", tag: "Volante", club: "Dock Sud", link: "https://www.instagram.com/p/DWt67IJES3Y/?igsh=ejlmMGF0a2drancz" },
  { img: "/jugador4-moran.jpeg", nombre: "Morán", tag: "Centro Delantero", club: "Real Pilar FC", link: "https://www.instagram.com/p/DVOhS3aDWaS/?igsh=ODN4Nmh3eXQyb3Y%3D" },
  { img: "/jugador5-ramirez.jpeg", nombre: "Leonel Ramírez", tag: "Defensor Central", club: "Deportivo Morón", link: "https://www.instagram.com/p/DRVrtgPjdh9/?igsh=MWR0OTlqYTFnYmVp" },
  { img: "/jugador6-abbruzzese.jpeg", nombre: "Matías Román Abbruzzese", tag: "Volante", club: "Midland", link: "https://www.instagram.com/p/DO4tCM_jaHq/?img_index=1&igsh=N3FpcmhjMTlyeW1v" },
  { img: "/jugador7-acosta.jpeg", nombre: "Elián Mira Acosta", tag: "Defensor", club: "Club Lanús", link: "https://www.instagram.com/p/DRlFUZbDfWe/?igsh=YmF6YXF5ZDh4b2g%3D0%2C0705" }, 
  { img: "/jugador8-benitez.jpeg", nombre: "Kevin Benítez", tag: "Volante", club: "Arsenal FC", link: "https://www.instagram.com/p/DWkcY_4DcKY/?igsh=MWoxMWdvZ2E4OHYzeg%3D%3D" },
  { img: "/jugador9-maldonado.jpeg", nombre: "Fer Maldonado", tag: "Delantero", club: "Argentino de Merlo", link: "https://www.instagram.com/p/DNyBCc92oe9/?igsh=dHJtM2h0ZXFvaHNp" },
  { img: "/jugador10-badur.jpeg", nombre: "Maxi Badur", tag: "Extremo", club: "Deportivo Morón", link: "https://www.instagram.com/p/DXk6BBZDaJA/?igsh=MXRiODl0bXh3cG9ocQ%3D%3D" },
  { img: "/jugador11-ledesma.jpeg", nombre: "Julián Ledesma", tag: "Delantero", club: "Arsenal FC", link: "https://www.instagram.com/p/DVwJjH0kRy6/?igsh=MWUzNXoyNnNueW1ldw%3D%3D" }
];
---

<Layout title="MGEO Sports | Representación de Futbolistas | Agente FIFA">
  
  <section class="relative bg-brand-dark text-white min-h-[90vh] md:min-h-screen flex items-center px-6 md:px-12 overflow-hidden pt-32 pb-20">
    <div class="absolute inset-0 z-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>
    <div class="absolute bottom-0 right-0 w-[40rem] h-[40rem] bg-brand-primary/15 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <div class="absolute -top-20 -right-20 w-[400px] h-[400px] md:top-1/2 md:-translate-y-1/2 md:right-0 md:w-[80vh] md:h-[80vh] opacity-[0.02] md:opacity-[0.03] pointer-events-none z-0 mix-blend-screen transition-all duration-700">
      <img src="/logo-sports.png" alt="" class="w-full h-full object-contain" />
    </div>

    <div class="container mx-auto max-w-5xl relative z-10 w-full">
      <div class="inline-flex items-center gap-3 mb-8 bg-white/5 border border-white/10 rounded-full px-5 py-2 backdrop-blur-sm max-w-full">
        <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse shrink-0"></span>
        <span class="text-gray-300 font-body text-[9px] md:text-[10px] tracking-widest uppercase font-bold whitespace-nowrap overflow-hidden text-ellipsis">Agencia de Representación</span>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-[6.5rem] font-heading font-bold leading-[1.05] mb-8 tracking-tighter">
        Representación <br />
        <span class="italic font-light text-gray-400">estratégica<span class="text-brand-primary">.</span></span>
      </h1>

      <p class="text-lg md:text-xl font-light text-gray-400 max-w-2xl mb-12 leading-relaxed border-l-2 border-brand-primary pl-6">
        Gestión integral bajo los más altos estándares internacionales de FIFA.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-6">
        <a href="#perfil-agente" class="text-white hover:text-brand-primary transition-colors font-body font-semibold text-[11px] uppercase tracking-[0.2em] group flex items-center justify-center gap-4 w-full sm:w-auto py-4">
          Perfil de Agencia <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-y-2 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </a>
        <a href="#talentos" class="bg-brand-primary text-white px-10 py-5 font-body font-bold uppercase tracking-[0.2em] text-[11px] hover:bg-white hover:text-brand-dark transition-all duration-500 w-full sm:w-auto text-center shadow-[0_10px_30px_-10px_rgba(120,22,22,0.5)]">
          Ver Roster Oficial
        </a>
      </div>
    </div>
  </section>

  <section id="perfil-agente" class="py-24 md:py-32 bg-white px-6 border-b border-gray-100">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        
        <div class="lg:col-span-5 relative order-2 lg:order-1 mt-10 lg:mt-0">
          <div class="aspect-[4/5] overflow-hidden rounded-sm relative z-10 shadow-2xl">
            <img src="/matias-sports.png" alt="Matías Georgetta - Agente FIFA" class="w-full h-full object-cover object-top grayscale hover:grayscale-0 transition-all duration-700" />
            <div class="absolute inset-0 bg-brand-dark/10 hover:bg-transparent transition-colors duration-500"></div>
          </div>
          <div class="absolute -bottom-6 -left-6 w-full h-full border-2 border-brand-primary/10 z-0 rounded-sm hidden md:block"></div>
        </div>

        <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center">
          <span class="text-brand-primary font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 block">Director & Agente</span>
          
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-brand-dark leading-[1.1] mb-8 tracking-tight">
            Matías Georgetta<br/>
            <span class="italic font-light text-gray-400">Agente Oficial.</span>
          </h2>
          
          <p class="text-gray-600 font-light text-base md:text-lg leading-relaxed mb-8">
            MGEO Sports fusiona el conocimiento exhaustivo del marco legal con la pasión por el fútbol. Al estar respaldados por nuestra propia firma jurídica, garantizamos que la carrera de nuestros seleccionados esté protegida, blindada y optimizada. Contamos con conexiones directas y licencia oficial para negociar en todo el mundo sin intermediarios.
          </p>

          <div class="mb-10">
            <a href="https://instagram.com/matias.georgetta" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-body font-medium text-brand-dark hover:text-brand-primary transition-colors pb-1 border-b border-gray-200 hover:border-brand-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.036 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/></svg>
              @matias.georgetta
            </a>
          </div>
          
          <div class="w-full max-w-[340px] rounded-lg overflow-hidden shadow-[0_10px_30px_-10px_rgba(0,59,113,0.2)] border border-gray-100 hover:scale-[1.02] transition-transform duration-500">
            <img src="/credencial-fifa.png" alt="Licencia FIFA Matías Georgetta" class="w-full h-auto object-contain" />
          </div>
          
        </div>
      </div>
    </div>
  </section>

  <section id="talentos" class="py-24 md:py-32 bg-brand-dark text-white px-6 border-y border-white/5 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[40rem] h-[40rem] bg-brand-primary/10 rounded-full blur-[120px] pointer-events-none hidden md:block z-0"></div>

    <div class="container mx-auto max-w-7xl relative z-10">
      
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <span class="text-brand-primary font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 block">Representación Oficial</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white tracking-tight">
            Talentos Exclusivos.
          </h2>
        </div>
        <div class="pb-2 hidden md:block">
          <a href="https://instagram.com/matias.georgetta" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors font-body text-[10px] md:text-xs uppercase tracking-[0.2em] flex items-center gap-3 border-b border-gray-700 hover:border-brand-primary pb-2 group">
            Ver firmas en Instagram
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-2 md:gap-3">
        {roster.slice(0, 4).map((jugador) => (
          <a href={jugador.link} target="_blank" rel="noopener noreferrer" class="group relative aspect-[4/5] bg-[#111] overflow-hidden cursor-pointer block rounded-sm border border-white/5 hover:border-brand-primary/40 hover:shadow-[0_10px_30px_-15px_rgba(120,22,22,0.4)] transition-all duration-500">
            <img src={jugador.img} alt={jugador.nombre} class="absolute inset-0 w-full h-full object-cover object-top md:grayscale group-hover:grayscale-0 scale-100 group-hover:scale-105 transition-all duration-1000 ease-[cubic-bezier(0.25,0.46,0.45,0.94)]" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/70 to-transparent opacity-95 md:group-hover:opacity-80 transition-opacity duration-700"></div>
            
            <div class="absolute bottom-0 left-0 w-full p-6 items-start z-20 flex flex-col">
              <span class="bg-brand-primary text-white px-2 py-1 text-[8px] font-bold tracking-[0.2em] uppercase rounded-sm mb-3 inline-block shadow-md">
                {jugador.tag}
              </span>
              <h3 class="text-2xl font-heading font-bold text-white mb-1 drop-shadow-md truncate w-full">{jugador.nombre}</h3>
              <div class="w-6 h-[2px] bg-white md:w-0 md:group-hover:w-10 group-hover:bg-brand-primary transition-all duration-700 ease-out my-3"></div>
              <div class="flex items-center justify-between w-full">
                <p class="text-[9px] font-body font-medium text-gray-300 uppercase tracking-[0.15em] truncate pr-2">{jugador.club}</p>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-brand-primary opacity-0 group-hover:opacity-100 transform -translate-x-2 group-hover:translate-x-0 transition-all duration-500 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="flex justify-center mt-12 md:mt-16">
        <a href="/roster" class="bg-brand-primary text-white px-10 py-5 font-body font-bold uppercase tracking-[0.2em] text-[11px] hover:bg-white hover:text-brand-dark transition-all duration-500 text-center shadow-[0_10px_30px_-10px_rgba(120,22,22,0.5)] flex items-center gap-3 w-full justify-center sm:w-auto">
          Explorar Roster Oficial Completo
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
        </a>
      </div>

    </div>
  </section>

  <section id="servicios-sports" class="py-24 md:py-32 bg-[#F9F8F6] px-6">
    <div class="container mx-auto max-w-6xl">
      
      <div class="text-center mb-20">
        <span class="text-brand-primary font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 block">Nuestra Infraestructura</span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-brand-dark leading-[1.1] mb-8 tracking-tight">Gestión Deportiva.</h2>
        <p class="text-gray-500 font-light text-base md:text-lg mt-4 max-w-2xl mx-auto leading-relaxed">Nuestros representados acceden a una estructura de protección y desarrollo que cubre todas sus necesidades profesionales.</p>
      </div>

      <div class="space-y-12">
        
        <div class="bg-white shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] border border-gray-100 flex flex-col xl:flex-row overflow-hidden">
          <div class="xl:w-5/12 bg-brand-dark text-white p-10 md:p-14 relative overflow-hidden flex flex-col justify-center">
            <div class="absolute top-0 left-0 w-64 h-64 bg-brand-primary/10 rounded-full blur-[80px]"></div>
            <div class="relative z-10">
              <h3 class="text-3xl md:text-4xl font-heading font-bold mb-6 leading-tight">Intermediación y <br/><span class="text-brand-primary italic">Transferencias</span></h3>
              <p class="text-gray-300 font-light mb-8 leading-relaxed">
                Gestión operativa y legal de contratos laborales con clubes a nivel nacional e internacional.
              </p>
            </div>
          </div>
          
          <div class="xl:w-7/12 p-10 md:p-14 bg-white flex flex-col justify-center">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <h4 class="text-brand-dark font-bold font-heading text-lg mb-2">Para Futbolistas</h4>
                <p class="text-gray-500 text-sm font-light leading-relaxed">Búsqueda de oportunidades de mercado, negociación de salarios, primas, bonos por objetivos y condiciones de traspaso.</p>
              </div>
              <div>
                <h4 class="text-brand-dark font-bold font-heading text-lg mb-2">Para Clubes</h4>
                <p class="text-gray-500 text-sm font-light leading-relaxed">Mandatos oficiales para scouting, colocación de jugadores y estructuración de operaciones de compra/venta o cesión.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] border border-gray-100 flex flex-col xl:flex-row-reverse overflow-hidden">
          <div class="xl:w-5/12 bg-[#161616] text-white p-10 md:p-14 relative overflow-hidden flex flex-col justify-center">
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-brand-primary/10 rounded-full blur-[80px]"></div>
            <div class="relative z-10">
              <h3 class="text-3xl md:text-4xl font-heading font-bold mb-6 leading-tight">Asesoramiento <br/><span class="text-brand-primary italic">Legal y Financiero</span></h3>
              <p class="text-gray-300 font-light mb-8 leading-relaxed">
                El respaldo directo del Estudio Jurídico MGEO aplicado a la carrera del deportista.
              </p>
            </div>
          </div>
          
          <div class="xl:w-7/12 p-10 md:p-14 bg-white flex flex-col justify-center">
            <p class="text-sm text-gray-500 font-light mb-6 border-l-2 border-brand-primary pl-4">
              Accedé a nuestra documentación técnica para entender cómo operamos en cada escenario legal del fútbol profesional:
            </p>

            <div class="space-y-4 w-full">
                <a href="/analisis#formacion" class="group flex flex-col sm:flex-row items-start sm:items-center gap-4 p-5 border border-gray-100 rounded-sm bg-gray-50/50 hover:bg-white hover:shadow-xl hover:border-brand-primary/30 transition-all duration-500 cursor-pointer">
                  <div class="flex items-start gap-4 flex-1">
                    <span class="text-brand-primary font-heading font-bold text-xl mt-0.5 opacity-80 group-hover:opacity-100 transition-opacity">01</span>
                    <div>
                      <h5 class="font-heading font-bold text-brand-dark mb-1 group-hover:text-brand-primary transition-colors">Derechos de Formación y Solidaridad</h5>
                      <p class="text-xs text-gray-500 font-light leading-relaxed">Gestión y reclamo ante FIFA por derechos formativos para clubes y academias.</p>
                    </div>
                  </div>
                  <div class="mt-4 sm:mt-0 flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-brand-dark group-hover:text-brand-primary transition-colors shrink-0">
                    Leer Análisis <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
                  </div>
                </a>

                <a href="/analisis#jurisdiccion" class="group flex flex-col sm:flex-row items-start sm:items-center gap-4 p-5 border border-gray-100 rounded-sm bg-gray-50/50 hover:bg-white hover:shadow-xl hover:border-brand-primary/30 transition-all duration-500 cursor-pointer">
                  <div class="flex items-start gap-4 flex-1">
                    <span class="text-brand-primary font-heading font-bold text-xl mt-0.5 opacity-80 group-hover:opacity-100 transition-opacity">02</span>
                    <div>
                      <h5 class="font-heading font-bold text-brand-dark mb-1 group-hover:text-brand-primary transition-colors">Conflictos Contractuales y Jurisdicción</h5>
                      <p class="text-xs text-gray-500 font-light leading-relaxed">Defensa en tribunales ordinarios o cámara de resolución de disputas (TAS/CAS).</p>
                    </div>
                  </div>
                  <div class="mt-4 sm:mt-0 flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-brand-dark group-hover:text-brand-primary transition-colors shrink-0">
                    Leer Análisis <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
                  </div>
                </a>

                <a href="/analisis#mercado" class="group flex flex-col sm:flex-row items-start sm:items-center gap-4 p-5 border border-gray-100 rounded-sm bg-gray-50/50 hover:bg-white hover:shadow-xl hover:border-brand-primary/30 transition-all duration-500 cursor-pointer">
                  <div class="flex items-start gap-4 flex-1">
                    <span class="text-brand-primary font-heading font-bold text-xl mt-0.5 opacity-80 group-hover:opacity-100 transition-opacity">03</span>
                    <div>
                      <h5 class="font-heading font-bold text-brand-dark mb-1 group-hover:text-brand-primary transition-colors">Operativa de Mercado y Transferencias</h5>
                      <p class="text-xs text-gray-500 font-light leading-relaxed">Estrategia en ventanas de pases, límites de inscripción (Regla 3-2) y normativas vigentes.</p>
                    </div>
                  </div>
                  <div class="mt-4 sm:mt-0 flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-brand-dark group-hover:text-brand-primary transition-colors shrink-0">
                    Leer Análisis <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
                  </div>
                </a>
            </div>
          </div>
        </div>

        <div class="bg-white shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] border border-brand-primary/20 flex flex-col xl:flex-row overflow-hidden relative">
          <div class="absolute top-0 left-0 w-1 h-full bg-brand-primary"></div>
          <div class="xl:w-5/12 bg-brand-dark text-white p-10 md:p-14 relative overflow-hidden flex flex-col justify-center">
            <div class="relative z-10">
              <h3 class="text-3xl md:text-4xl font-heading font-bold mb-6 leading-tight">Desarrollo de <br/><span class="text-brand-primary italic">Imagen y Sponsoreo</span></h3>
              <p class="text-gray-300 font-light leading-relaxed">
                El futbolista actual es una marca. Gestionamos acuerdos comerciales y presencia digital para maximizar los ingresos extra-deportivos.
              </p>
