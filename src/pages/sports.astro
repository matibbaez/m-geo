  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const wpForm = document.getElementById('wp-form-sports') as HTMLFormElement | null;
      
      if (wpForm) {
        wpForm.addEventListener('submit', function(e) {
          e.preventDefault(); 

          const nombreInput = document.getElementById('nombre_sports') as HTMLInputElement | null;
          const contactoInput = document.getElementById('contacto_dato_sports') as HTMLInputElement | null;
          const selectArea = document.getElementById('area_sports') as HTMLSelectElement | null;
          const mensajeInput = document.getElementById('mensaje_sports') as HTMLTextAreaElement | null;

          if (!nombreInput || !contactoInput || !selectArea || !mensajeInput) return;

          const nombre = nombreInput.value;
          const contacto = contactoInput.value;
          const area = selectArea.options[selectArea.selectedIndex].value;
          const mensaje = mensajeInput.value;

          // ⚠️ IMPORTANTE: PONER EL NÚMERO DE TELÉFONO DEL ÁREA SPORTS ⚠️
          const numeroWhatsApp = "5491100000000";

          const textoBase = 
`Hola MGEO Sports, me contacto desde la web para realizar una consulta.

*Datos del remitente:*
👤 Jugador / Entidad: ${nombre}
📞 Contacto alternativo: ${contacto}

*Motivo principal:*
⚽ ${area}

*Detalle / Información extra:*
${mensaje}

Aguardo sus comentarios. ¡Gracias!`;

          const textoCodificado = encodeURIComponent(textoBase);
          const urlWhatsApp = `https://wa.me/${numeroWhatsApp}?text=${textoCodificado}`;
          
          window.open(urlWhatsApp, '_blank');
        });
      }
    });
  </script>

